# OWL Sing Together — env vars
# Copy to .env.local and fill in real values. Never commit .env.local.
# Canonical names per ../OWL-Obsidian-Brain/11_Tech_Requirements/TECH_STACK.md §9.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Sanity (CMS) ─────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=
# Public mirrors (used by the embedded Studio + browser preview)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ── Supabase (auth + DB) ────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Public mirrors (used by the browser client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Shopify (commerce) ──────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_TOKEN=

# ── Printify / Gumroad ──────────────────────────────────────────────────────
PRINTIFY_API_KEY=
GUMROAD_API_KEY=

# ── Stripe (subscriptions + digital + educator) ─────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email ───────────────────────────────────────────────────────────────────
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
CONVERTKIT_API_KEY=
RESEND_API_KEY=

# ── Cloudflare R2 (gated PDFs + image CDN) ──────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=

# ── Analytics ───────────────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=

# ── AI / voice ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=

# ── Automation ──────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=

# ── Airtable (product DB + School CRM) ──────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
