{
  "name": "owl-website",
  "version": "0.1.0",
  "private": true,
  "description": "OWL Sing Together — public website, blog, store, newsletter, admin CRM, curriculum portal. Source of truth: ../OWL-Obsidian-Brain.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "sanity:deploy": "sanity deploy",
    "sanity:graphql:deploy": "sanity graphql deploy",
    "supabase:gen-types": "supabase gen types typescript --local > src/types/database.ts",
    "generate:hero-frame-smoke": "node scripts/generate-hero-frame-smoke.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "fetch:youtube": "node scripts/fetch-youtube-videos.mjs",
    "fetch:youtube:write": "node scripts/fetch-youtube-videos.mjs --write",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@portabletext/react": "^3.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@react-email/components": "^0.0.25",
    "@sanity/client": "^6.22.0",
    "@sanity/image-url": "^1.0.2",
    "@sanity/vision": "^3.62.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.5.0",
    "gsap": "^3.12.5",
    "@gsap/react": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "^15.5.18",
    "next-sanity": "^9.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^3.0.0",
    "react-hook-form": "^7.53.0",
    "resend": "^4.0.0",
    "sanity": "^3.62.0",
    "stripe": "^17.2.0",
    "styled-components": "^6.1.13",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.18",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styled-components": "^5.1.34",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0"
  }
}
