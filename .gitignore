# OS
Thumbs.db

# Reference-only assets — kept on disk for dev convenience, never shipped.
# Wireframes live here so devs can compare a page they're building against
# the canonical wireframe without leaving the repo.
/public/images/wireframes-reference/

# Dev-only smoke fixtures for <HeroFrameSequence>.
# Generated by `npm run generate:hero-frame-smoke`. Never commit.
/public/images/hero-frames/_dev-smoke/

# YouTube RSS scrape output. Generated by `npm run fetch:youtube`.
# Used as a reference while editing videos.ts. Never commit.
/scripts/.youtube-channel-videos.json
